# OAuth client used by the api/ functions to act as the Google account that
# owns the Drive folder. See README.md for how to create these and how to
# generate GOOGLE_OAUTH_REFRESH_TOKEN via the one-time /api/auth/google flow.
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback
GOOGLE_OAUTH_REFRESH_TOKEN=generated-via-the-one-time-/api/auth/google-flow
GOOGLE_DRIVE_FOLDER_ID=the-id-from-the-drive-folder-url
